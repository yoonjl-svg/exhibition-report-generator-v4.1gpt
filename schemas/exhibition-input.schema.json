{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yoonjl-svg.github.io/exhibition-report-generator-v4.1gpt/schemas/exhibition-input.schema.json",
  "title": "Ilmin Exhibition Report Input",
  "description": "Curator-authored input data used to generate an evidence-backed Analysis Ledger.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "exhibition",
    "audience",
    "budget",
    "programs",
    "publicity",
    "reference_groups"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.2\\.\\d+$"
    },
    "exhibition": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "title", "period", "venue"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string" },
        "venue": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "period": {
          "type": "object",
          "additionalProperties": false,
          "required": ["display"],
          "properties": {
            "start": { "type": "string" },
            "end": { "type": "string" },
            "display": { "type": "string", "minLength": 1 }
          }
        },
        "scope_note": { "type": "string" }
      }
    },
    "brief_metric_ids": {
      "type": "array",
      "items": { "type": "string" },
      "default": [
        "total_visitors",
        "daily_visitors",
        "total_budget",
        "budget_execution_rate",
        "total_income",
        "cost_per_visitor",
        "paid_audience_ratio",
        "group_audience_ratio",
        "program_sessions",
        "program_participants",
        "press_mentions",
        "sns_feedback"
      ]
    },
    "narrative": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "theme_and_content": { "type": "string" },
        "composition_note": { "type": "string" },
        "evaluation_note": { "type": "string" }
      }
    },
    "audience": {
      "type": "object",
      "additionalProperties": true,
      "required": ["total_visitors", "operating_days"],
      "properties": {
        "total_visitors": { "type": "number", "minimum": 0 },
        "operating_days": { "type": "number", "exclusiveMinimum": 0 },
        "daily_visitors": { "type": "number", "minimum": 0 },
        "paid_visitors": { "type": "number", "minimum": 0 },
        "free_visitors": { "type": "number", "minimum": 0 },
        "group_visitors": { "type": "number", "minimum": 0 },
        "group_audience_ratio": { "type": "number", "minimum": 0 }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": true,
      "required": ["total_budget"],
      "properties": {
        "total_budget": { "type": "number", "minimum": 0 },
        "allocated_budget": { "type": "number", "minimum": 0 },
        "execution_rate": { "type": "number", "minimum": 0 },
        "income": { "type": "number", "minimum": 0 }
      }
    },
    "programs": {
      "type": "object",
      "additionalProperties": true,
      "required": ["count", "participants"],
      "properties": {
        "count": { "type": "number", "minimum": 0 },
        "sessions": { "type": "number", "minimum": 0 },
        "participants": { "type": "number", "minimum": 0 },
        "participation_rate": { "type": "number", "minimum": 0 }
      }
    },
    "publicity": {
      "type": "object",
      "additionalProperties": true,
      "required": ["press_mentions"],
      "properties": {
        "press_mentions": { "type": "number", "minimum": 0 },
        "sns_posts": { "type": "number", "minimum": 0 },
        "sns_feedback_total": { "type": "number", "minimum": 0 },
        "press_reach_note": { "type": "string" }
      }
    },
    "membership": {
      "type": "object",
      "additionalProperties": true
    },
    "reference_groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "selection_rule", "caveat", "metrics"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "selection_rule": { "type": "string", "minLength": 1 },
          "caveat": { "type": "string", "minLength": 1 },
          "metrics": {
            "type": "object",
            "additionalProperties": { "type": "number" }
          }
        }
      }
    },
    "selected_feedback": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "theme", "polarity", "quote"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "theme": { "type": "string", "minLength": 1 },
          "polarity": {
            "type": "string",
            "enum": ["positive", "critical", "suggestion", "neutral"]
          },
          "quote": { "type": "string", "minLength": 1 },
          "note": { "type": "string" }
        }
      },
      "default": []
    },
    "data_quality_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "claim", "importance", "sources"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "claim": { "type": "string", "minLength": 1 },
          "importance": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "caveat": { "type": "string" },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "value"],
              "properties": {
                "label": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          }
        }
      },
      "default": []
    }
  }
}
